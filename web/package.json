{
  "name": "playable-player-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:https": "PLAYABLE_HTTPS=1 vite --host 0.0.0.0",
    "build": "vite build",
    "build:pages": "PLAYABLE_BASE=${PLAYABLE_BASE:-/playableplayer/} vite build",
    "preview": "vite preview --host 0.0.0.0",
    "mobile": "npm run build && vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "jszip": "^3.10.1",
    "vite": "^7.1.7"
  },
  "devDependencies": {}
}
